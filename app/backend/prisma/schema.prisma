datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// 1. Definición de Roles para el Control de Accesos
enum Rol {
  ADMIN
  PRODUCTOR
  CLIENTE
}

// 2. Modelo de Empresas
model Empresa {
  id            String             @id @default(uuid())
  nombre        String
  fechaRegistro DateTime           @default(now())
  
  usuarios      Usuario[]
  dispositivos  Dispositivo[]
  asignaciones  AsignacionMusica[]
}

// 3. Modelo de Usuarios (Admin, Productor, Cliente)
model Usuario {
  id           String             @id @default(uuid())
  nombre       String
  email        String             @unique
  passwordHash String
  rol          Rol
  
  // Relación opcional con Empresa: Un cliente pertenece a una empresa.
  // Admins y Productores pueden tener este campo como null (alcance global).
  empresaId    String?
  empresa      Empresa?           @relation(fields: [empresaId], references: [id])
  
  // Relaciones inversas
  cancionesSubidas Cancion[]
  asignacionesHechas AsignacionMusica[]
}

// 4. Modelo de Dispositivos (Hardware único)
model Dispositivo {
  id              String   @id @default(uuid())
  dispositivoUuid String   @unique // Aquí guardas la dirección MAC, serial o token único del chip
  nombre          String   // Ej: "Altavoz Pasillo Principal"
  estado          String   @default("offline") // online, offline, playing
  fechaRegistro   DateTime @default(now())
  
  // Relación obligatoria: Cada dispositivo pertenece a una empresa
  empresaId       String
  empresa         Empresa  @relation(fields: [empresaId], references: [id])
}

// 5. Modelo de Canciones
model Cancion {
  id           String             @id @default(uuid())
  titulo       String
  urlArchivo   String             // URL del almacenamiento en la nube (ej. S3, Firebase)
  fechaSubida  DateTime           @default(now())
  
  // Relación: Quién subió la canción (Productor o Admin)
  subidoPorId  String
  subidoPor    Usuario            @relation(fields: [subidoPorId], references: [id])
  
  asignaciones AsignacionMusica[]
}

// 6. Tabla Intermedia: Controla qué música va a qué empresa
model AsignacionMusica {
  id            String   @id @default(uuid())
  fechaAsignado DateTime @default(now())
  
  empresaId     String
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  
  cancionId     String
  cancion       Cancion  @relation(fields: [cancionId], references: [id])
  
  // Registro de qué productor realizó la acción
  asignadoPorId String
  asignadoPor   Usuario  @relation(fields: [asignadoPorId], references: [id])

  // Restricción: Evita asignar la misma canción más de una vez a la misma empresa
  @@unique([empresaId, cancionId])
}